# ===========================================
# SocialAI Pro Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control!

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================

# Application basic information
VITE_APP_NAME="SocialAI Pro"
VITE_APP_VERSION="1.0.0"
VITE_APP_DESCRIPTION="AI-Powered Social Media Management Platform"

# Environment (development, staging, production)
VITE_NODE_ENV="development"

# Application URLs
VITE_APP_URL="http://localhost:5173"
VITE_API_BASE_URL="http://localhost:5173/api"

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Required for database, authentication, and real-time features
# Get these from your Supabase project dashboard: https://app.supabase.io

# Supabase project URL (format: https://your-project-ref.supabase.co)
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase anonymous key (safe to use in frontend)
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key_here"

# Supabase service role key (BACKEND ONLY - never expose in frontend)
# Only needed for server-side operations and Edge Functions
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"

# ===========================================
# SOCIAL MEDIA API INTEGRATIONS
# ===========================================

# Ayrshare API - For posting to multiple social media platforms
# Sign up at: https://ayrshare.com
VITE_AYRSHARE_API_KEY="your_ayrshare_api_key_here"
VITE_AYRSHARE_BASE_URL="https://app.ayrshare.com/api"

# Optional: Individual platform API keys (if not using Ayrshare)
# Twitter API v2
VITE_TWITTER_API_KEY="your_twitter_api_key"
VITE_TWITTER_API_SECRET="your_twitter_api_secret"
VITE_TWITTER_BEARER_TOKEN="your_twitter_bearer_token"

# Facebook/Meta API
VITE_FACEBOOK_APP_ID="your_facebook_app_id"
VITE_FACEBOOK_APP_SECRET="your_facebook_app_secret"

# LinkedIn API
VITE_LINKEDIN_CLIENT_ID="your_linkedin_client_id"
VITE_LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret"

# Instagram Basic Display API
VITE_INSTAGRAM_APP_ID="your_instagram_app_id"
VITE_INSTAGRAM_APP_SECRET="your_instagram_app_secret"

# ===========================================
# AI SERVICES CONFIGURATION
# ===========================================

# OpenAI API - For AI content suggestions and optimization
# Get your key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY="your_openai_api_key_here"
VITE_OPENAI_MODEL="gpt-4"
VITE_OPENAI_MAX_TOKENS="1000"

# Alternative AI Services (choose one or configure multiple)
# Anthropic Claude API
VITE_ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Google AI/Gemini API
VITE_GOOGLE_AI_API_KEY="your_google_ai_api_key_here"

# Hugging Face API (for open-source models)
VITE_HUGGINGFACE_API_KEY="your_huggingface_api_key_here"

# ===========================================
# ANALYTICS & MONITORING
# ===========================================

# Google Analytics 4
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Mixpanel Analytics
VITE_MIXPANEL_TOKEN="your_mixpanel_token_here"

# Sentry Error Tracking
VITE_SENTRY_DSN="your_sentry_dsn_here"
VITE_SENTRY_ENVIRONMENT="development"

# PostHog Analytics
VITE_POSTHOG_API_KEY="your_posthog_api_key_here"
VITE_POSTHOG_HOST="https://app.posthog.com"

# ===========================================
# EMAIL & COMMUNICATION
# ===========================================

# SendGrid - For email notifications and invitations
VITE_SENDGRID_API_KEY="your_sendgrid_api_key_here"

# Resend - Alternative email service
VITE_RESEND_API_KEY="your_resend_api_key_here"

# Twilio - For SMS notifications (optional)
VITE_TWILIO_ACCOUNT_SID="your_twilio_account_sid"
VITE_TWILIO_AUTH_TOKEN="your_twilio_auth_token"

# ===========================================
# FILE STORAGE & CDN
# ===========================================

# AWS S3 (if using custom file storage)
VITE_AWS_ACCESS_KEY_ID="your_aws_access_key_id"
VITE_AWS_SECRET_ACCESS_KEY="your_aws_secret_access_key"
VITE_AWS_REGION="us-east-1"
VITE_AWS_S3_BUCKET="your-s3-bucket-name"

# Cloudinary (for image processing and CDN)
VITE_CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
VITE_CLOUDINARY_API_KEY="your_cloudinary_api_key"
VITE_CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# ===========================================
# THIRD-PARTY INTEGRATIONS
# ===========================================

# Stripe (for payment processing)
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"

# PayPal (alternative payment processor)
VITE_PAYPAL_CLIENT_ID="your_paypal_client_id"

# Zapier (for workflow automation)
VITE_ZAPIER_WEBHOOK_URL="your_zapier_webhook_url"

# ===========================================
# DEVELOPMENT & TESTING
# ===========================================

# Development flags
VITE_ENABLE_DEVTOOLS="true"
VITE_ENABLE_MOCK_DATA="false"
VITE_DEBUG_MODE="true"

# Testing configuration
VITE_TEST_USER_EMAIL="test@example.com"
VITE_TEST_USER_PASSWORD="test_password_123"

# Feature flags
VITE_FEATURE_AI_SUGGESTIONS="true"
VITE_FEATURE_TEAM_COLLABORATION="true"
VITE_FEATURE_ADVANCED_ANALYTICS="true"
VITE_FEATURE_DARK_MODE="true"

# ===========================================
# SECURITY CONFIGURATION
# ===========================================

# JWT Configuration (if using custom auth)
JWT_SECRET="your_jwt_secret_key_here"
JWT_EXPIRES_IN="7d"

# CORS Configuration
VITE_CORS_ORIGIN="http://localhost:5173"

# Rate limiting
VITE_RATE_LIMIT_REQUESTS="100"
VITE_RATE_LIMIT_WINDOW="15"

# ===========================================
# PRODUCTION OVERRIDES
# ===========================================
# These variables will be automatically set in production
# Do not modify unless you know what you're doing

# Production API URLs (automatically set by deployment platform)
# VITE_APP_URL="https://your-production-domain.com"
# VITE_API_BASE_URL="https://your-production-domain.com/api"

# Production database (automatically configured in Supabase)
# VITE_SUPABASE_URL="https://your-prod-project.supabase.co"

# ===========================================
# NOTES & SECURITY REMINDERS
# ===========================================

# SECURITY NOTES:
# 1. NEVER commit API keys to version control
# 2. Use VITE_ prefix only for variables that are safe to expose in the browser
# 3. Keep sensitive keys (like service role keys) on the server side only
# 4. Rotate API keys regularly
# 5. Use different keys for development, staging, and production

# REQUIRED VARIABLES:
# At minimum, you need:
# - VITE_SUPABASE_URL
# - VITE_SUPABASE_ANON_KEY
# - VITE_AYRSHARE_API_KEY (for social media posting)
# - VITE_OPENAI_API_KEY (for AI features)

# OPTIONAL VARIABLES:
# All other variables are optional and enable additional features
# The application will work with just the required variables

# HOW TO GET API KEYS:
# 1. Supabase: Create account at https://supabase.io
# 2. Ayrshare: Sign up at https://ayrshare.com
# 3. OpenAI: Get API key from https://platform.openai.com
# 4. Other services: Visit their respective websites

# TESTING YOUR CONFIGURATION:
# 1. Copy this file to .env.local
# 2. Fill in required variables
# 3. Run `npm run dev`
# 4. Check browser console for any configuration errors